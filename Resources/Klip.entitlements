<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Intentionally empty: NO App Sandbox, so the app can store its history in
         ~/Library/Application Support/Klip and synthesize ⌘V (auto-paste).
         A separate sandboxed entitlements file is required for a Mac App Store build. -->
</dict>
</plist>
